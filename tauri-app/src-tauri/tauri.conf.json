{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "InFlow",
  "version": "0.1.0",
  "identifier": "com.alexz.tauri-app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "inFlow Workspace",
        "width": 1200,
        "height": 800,
        "visible": false
      },
      {
        "label": "overlay",
        "title": "inFlow 翻译",
        "width": 480,
        "height": 580,
        "resizable": true,
        "decorations": false,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "visible": false,
        "transparent": true
      }
    ],
    "security": {
      "csp": null,
      "capabilities": ["default", "overlay"]
    },
    "withGlobalTauri": true
  },
  "bundle": {
    "active": true,
    "targets": "nsis",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
